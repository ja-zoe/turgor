# ============================================================================
# Turgor — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# ---- Database (Supabase Postgres) -----------------------------------------
# From Supabase: Project Settings → Database → Connection string.
# DATABASE_URL uses the pooled (PgBouncer, port 6543) connection for the app.
# DIRECT_URL uses the direct (port 5432) connection for migrations.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Supabase Storage (optional — org logo uploads, R29.1) -----------------
# Same Supabase project as the database. Project Settings → API keys: the project
# URL and a secret key (sb_secret_…; the legacy service_role JWT also works via
# SUPABASE_SERVICE_ROLE_KEY). SERVER ONLY — never expose the secret to the
# browser. When unset, the logo upload control is disabled and URL entry works.
# SUPABASE_URL="https://<ref>.supabase.co"
# SUPABASE_SECRET_KEY="sb_secret_..."

# ---- Auth.js / NextAuth ----------------------------------------------------
# Generate with: `openssl rand -base64 32`
AUTH_SECRET="replace-me-with-a-long-random-string"
# Base URL of the app. Required in production (e.g. https://turgor-myorg.vercel.app).
# Optional in local dev (defaults to http://localhost:3000).
# AUTH_URL="http://localhost:3000"

# ---- Sign-in provider -------------------------------------------------------
# The sign-in method is chosen in the app (Org Settings → Sign-in method; new
# installations default to email magic links). Setting AUTH_PROVIDER here
# OVERRIDES that setting and locks the control — an operator/testing escape
# hatch, not the normal configuration path.
#   "cas"    → CAS single sign-on, or its local mock (see CAS_MODE below).
#   "email"  → email magic links via Resend (RESEND_API_KEY required).
#              ALLOWED_EMAIL_DOMAINS still applies: empty means any domain may
#              request a link; set it to restrict sign-in to your org's domain(s).
# AUTH_PROVIDER="cas"

# Dev/e2e only: with AUTH_EMAIL_TEST_CAPTURE=1 the magic-link request endpoint
# returns the sign-in link to JSON callers instead of emailing it. Ignored in
# production builds.
# AUTH_EMAIL_TEST_CAPTURE="1"

# ---- Rutgers CAS (Central Authentication Service) --------------------------
# Sign-in uses CAS (Rutgers' SSO), NOT Google OAuth.
#
# CAS_MODE:
#   "mock"  → (default) local stand-in CAS screen at /dev-login. Use this until
#             the app's service URL is registered with Rutgers IdM. Lets you run
#             and demo the whole app immediately.
#   "real"  → talk to the actual Rutgers CAS server. Requires that the IdM team
#             has registered this app's service URL (Enterprise CAS request form).
CAS_MODE="mock"

# Real CAS server base URL (only used when CAS_MODE=real). Confirm the exact
# value + validation path in the Rutgers CAS docs/FAQ before launch.
CAS_BASE_URL="https://cas.rutgers.edu"

# Domain a NetID maps to (NetID -> <netid>@<CAS_EMAIL_DOMAIN>).
CAS_EMAIL_DOMAIN="scarletmail.rutgers.edu"

# Comma-separated list of allowed email domains. Sign-in is rejected for any
# email outside these domains. Verify the exact Rutgers domain(s) before launch.
ALLOWED_EMAIL_DOMAINS="scarletmail.rutgers.edu,rutgers.edu"

# Email address of the initial Project Manager (admin). On first sign-in this
# account is auto-activated and granted the Project Manager role by the seed.
# In mock CAS, sign in with this NetID (the part before @) to land as the PM.
PM_ADMIN_EMAIL="your-pm-netid@scarletmail.rutgers.edu"

# ---- Email (Resend) --------------------------------------------------------
# Free tier: https://resend.com . Used for reminder / trigger emails.
# If RESEND_API_KEY is unset, email sending is skipped (in-app notifications
# still work), so the app remains usable without configuring email.
RESEND_API_KEY=""
EMAIL_FROM="Turgor <onboarding@resend.dev>"

# Shared secret protecting the notifications cron endpoint
# (POST /api/cron/notifications, called by Vercel Cron or the run script).
CRON_SECRET="replace-me-with-a-random-string"

# ---- Stytch (MCP OAuth for ChatGPT — Set 17 / R17.2) -----------------------
# Lets ChatGPT's web "custom connectors" authenticate to the MCP server via OAuth,
# while keeping Rutgers CAS as the actual login (Stytch Connected Apps). Only needed
# for the ChatGPT/remote-MCP path; the static /account token still works without it.
# Find these in the Stytch dashboard → API Keys (use the TEST keys in dev, LIVE in prod).
STYTCH_PROJECT_ID="project-test-00000000-0000-0000-0000-000000000000"
STYTCH_SECRET="secret-test-replace-me"            # SERVER ONLY — never expose to the browser
STYTCH_PUBLIC_TOKEN="public-token-test-replace-me"
# If the public token ever needs to be read in the browser, add a NEXT_PUBLIC_ alias:
# NEXT_PUBLIC_STYTCH_PUBLIC_TOKEN="public-token-test-replace-me"
# The Stytch project's domain = its OAuth Authorization Server issuer (Stytch Dashboard →
# Connected Apps). Whole base URL, NO trailing slash, NO path — Stytch hosts the discovery
# doc at <domain>/.well-known/oauth-authorization-server. Published in our
# /.well-known/oauth-protected-resource so ChatGPT can discover where to authorize.
STYTCH_OAUTH_AUTHORIZATION_SERVER="https://your-project-domain.customers.stytch.com"
# The Trusted Auth Token Profile ID (Stytch Dashboard → Connected Apps → your token
# profile). The /oauth/authorize consent page passes it to Stytch's IdentityProvider so it
# knows which profile to validate our minted JWT against.
STYTCH_TRUSTED_TOKEN_PROFILE_ID="trusted-auth-token-profile-..."
# RS256 private key (JWK JSON, single line) used to sign the "trusted auth token" our
# /oauth/authorize route hands to Stytch. SERVER-ONLY SECRET. Generate once and reuse in
# prod (set the SAME value in Vercel). The public half is published at /.well-known/jwks.json.
# Generate: see scripts (jose generateKeyPair RS256 → exportJWK). Example shape:
MCP_OAUTH_PRIVATE_KEY='{"kty":"RSA","n":"...","e":"AQAB","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"...","kid":"<uuid>","alg":"RS256","use":"sig"}'
