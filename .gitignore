# ---- Dependencies ----
/node_modules
/.pnp
.pnp.*
.yarn/*

# ---- Next.js build output ----
/.next/
/out/
next-env.d.ts

# ---- Production ----
/build

# ---- Prisma ----
# Generated client (regenerated by `pnpm prisma generate`)
/src/generated
# Local SQLite dev databases, if ever used
*.db
*.db-journal

# ---- Environment & secrets ----
# Never commit real credentials (Google OAuth, Supabase, Resend, NextAuth secret)
.env
.env*.local
.env.production

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Testing ----
/coverage

# ---- Misc / editor / OS ----
.DS_Store
*.pem
.vscode/*
!.vscode/extensions.json
.idea
.vercel
*.tsbuildinfo

# ---- Claude Code internal ----
.claude/worktrees/

# ---- Planning / source material (kept local, not part of the app) ----
# The `claude/` folder holds the planning outline and the design-system skill
# used to build this app; it is reference material, not shipped code.
/claude

/src/generated/prisma
# Claude Code + dev tooling (local-only; agents are in .agents/ which is tracked)
.claude/

# Spec-driven-dev (development tracking)
changes/

# End-to-end tests
e2e/
playwright.config.ts

# Development artifacts
.next/

# gnhf run logs (local-only)
.gnhf/

# Local Claude Code entrypoint (symlink to the tracked AGENTS.md)
/CLAUDE.md
