generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Permission {
  VIEW_ALL_PROJECTS
  VIEW_ASSIGNED_PROJECTS // retired R26.1 — do not grant; no gate reads it. Kept because Postgres enum values can't be dropped safely.
  SUBMIT_STATUS_UPDATES
  EDIT_OWN_PROJECT
  POST_MEETING_TRACKING
  MANAGE_PROJECTS
  MANAGE_MILESTONES
  ASSIGN_ACTION_ITEMS
  CLOSE_ACTION_ITEMS
  VIEW_MONTHLY_REVIEW
  CONFIGURE_NOTIFICATIONS
  MANAGE_USERS
  MANAGE_ROLES
  MANAGE_CALENDAR
  VIEW_LEAD_MEETINGS
  MANAGE_STATUS_UPDATES
  MANAGE_MEETING_RECORDS
  DELETE_USERS
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum McpConnectionType {
  ACCESS_TOKEN
  OAUTH
}

enum ProjectStatus {
  ON_TRACK
  AT_RISK
  BEHIND
}

// Shared status enum for Deliverable and Subtask
enum TimelineStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectMemberRole {
  LEAD
  SUBLEAD
  MEMBER
}

enum ActionItemStatus {
  OPEN
  DONE
}

enum TriggerType {
  MISSING_SUBMISSION
  PROJECT_BEHIND
  ACTION_ITEM_DUE
  GOAL_MISSED
}

enum Channel {
  EMAIL
  IN_APP
  BOTH
}

enum RecipientGroup {
  PM
  PROJECT_LEADS
  ACTION_OWNER
  ALL_ACTIVE
}

enum NotificationType {
  REMINDER
  PROJECT_BEHIND
  ACTION_ITEM
  GOAL_MISSED
  USER_APPROVAL
  GENERAL
  USER_SIGNUP
}

// ─── Auth adapter models (required by Auth.js Prisma adapter) ───────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Tenancy (R35.1) ─────────────────────────────────────────────────────────

// The tenant root. One row per org; a stock/free-tier install has exactly one
// ("default"). Billing/plan/entitlement columns live in the private turgor-cloud
// repo and hang off this id — keep this model minimal and stable.
model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique // stable handle; future subdomain/vanity routing (column now, routing later)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        Membership[]
  roles              Role[]
  settings           Settings?
  projects           Project[]
  projectAssignments ProjectAssignment[]
  deliverables       Deliverable[]
  subtasks           Subtask[]
  statusUpdates      StatusUpdate[]
  meetingRecords     MeetingRecord[]
  actionItems        ActionItem[]
  notificationRules  NotificationRule[]
  notifications      Notification[]
  calendarEvents     CalendarEvent[]
  mcpConnections     McpConnection[]
}

// User↔org link. Owns the per-org role and activation state (a user can be an
// ACTIVE Project Manager in one org and a PENDING Viewer in another).
model Membership {
  id        String     @id @default(cuid())
  userId    String
  orgId     String
  roleId    String? // org-scoped global role (PM/Lead/Viewer)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role Role?        @relation(fields: [roleId], references: [id])

  @@unique([userId, orgId])
  @@index([orgId])
}

// ─── Domain models ──────────────────────────────────────────────────────────

model Role {
  id          String       @id @default(cuid())
  orgId       String
  name        String
  isBuiltIn   Boolean      @default(false)
  // Stable identity for seeded roles ('pm' | 'lead' | 'viewer' | 'eboard') so code
  // never depends on the PM-editable display name. NULL for custom roles.
  builtInKey  String?
  permissions Permission[]

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  memberships Membership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
  @@unique([orgId, builtInKey])
  @@index([orgId])
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  firstName     String?
  lastName      String?
  nickname      String?
  mcpToken      String?    @unique
  // R35.4: the org a personal MCP token acts in (set when the token is generated).
  // An MCP call carries no session, so the token names its org.
  mcpTokenOrgId String?
  // R27.2: recipient-side mute for the EMAIL channel; in-app delivery unaffected.
  emailNotifications Boolean @default(true)

  // R35.3 (contract): global role + activation moved to Membership (per-org). User is
  // now pure global identity; org access + role/status live on `memberships`.
  memberships        Membership[]
  accounts           Account[]
  sessions           Session[]
  projectAssignments ProjectAssignment[]
  statusUpdates      StatusUpdate[]
  meetingRecords     MeetingRecord[]
  assignedSubtasks   Subtask[]           @relation("SubtaskAssignee")
  actionItems        ActionItem[]        @relation("ActionItemOwner")
  notifications      Notification[]
  mcpConnections     McpConnection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model McpConnection {
  id         String            @id @default(cuid())
  orgId      String
  userId     String
  org        Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       McpConnectionType
  clientId   String? // OAuth client id (from the token); "personal" sentinel for personal token
  label      String? // friendly name, e.g. "ChatGPT" or "Personal access token"
  createdAt  DateTime          @default(now())
  lastSeenAt DateTime          @default(now())

  @@unique([userId, type, clientId])
  @@index([orgId])
}

model Project {
  id                   String        @id @default(cuid())
  orgId                String
  name                 String
  description          String?
  semester             String
  status               ProjectStatus @default(ON_TRACK)
  statusOverride       Boolean       @default(false)
  correctiveActionPlan String?       @db.Text
  startDate            DateTime?
  endDate              DateTime?
  archivedAt           DateTime?

  org             Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignments     ProjectAssignment[]
  deliverables    Deliverable[]
  statusUpdates   StatusUpdate[]
  meetingRecords  MeetingRecord[]
  actionItems     ActionItem[]
  calendarEvents  CalendarEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model ProjectAssignment {
  id        String            @id @default(cuid())
  orgId     String
  projectId String
  userId    String
  role      ProjectMemberRole

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([orgId])
}

model Deliverable {
  id            String         @id @default(cuid())
  orgId         String
  projectId     String
  title         String
  description   String?        @db.Text
  status        TimelineStatus @default(NOT_STARTED)
  startDate     DateTime?
  targetDate    DateTime
  completed     Boolean        @default(false)
  completedDate DateTime?
  orderIndex    Int            @default(0)
  group         String?
  priority      Priority       @default(MEDIUM)
  backlog       Boolean        @default(false)

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subtasks Subtask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([projectId])
}

model Subtask {
  id            String         @id @default(cuid())
  orgId         String
  deliverableId String
  title         String
  description   String?        @db.Text
  status        TimelineStatus @default(NOT_STARTED)
  startDate     DateTime?
  dueDate       DateTime?
  orderIndex    Int            @default(0)
  assigneeId    String?
  completedAt   DateTime?

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliverable Deliverable  @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  assignee    User?        @relation("SubtaskAssignee", fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([assigneeId, status])
  @@index([deliverableId])
}

model StatusUpdate {
  id             String   @id @default(cuid())
  orgId          String
  projectId      String
  submittedById  String
  meetingDate    DateTime
  plannedWork    String   @db.Text
  actualProgress String   @db.Text
  blockers       String   @db.Text
  nextWeekGoals  String   @db.Text
  needsHelp      Boolean  @default(false)
  helpNeeded     String?  @db.Text
  submittedAt    DateTime @default(now())
  isLate         Boolean  @default(false)
  calendarEventId String?

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedBy   User           @relation(fields: [submittedById], references: [id])
  calendarEvent CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([projectId, meetingDate])
}

model MeetingRecord {
  id           String        @id @default(cuid())
  orgId        String
  projectId    String
  meetingDate  DateTime
  status       ProjectStatus
  goalMet      Boolean?
  keyBlockers  String?       @db.Text
  notes        String?       @db.Text
  recordedById String

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordedBy  User         @relation(fields: [recordedById], references: [id])
  actionItems ActionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([projectId, meetingDate])
}

model ActionItem {
  id          String           @id @default(cuid())
  orgId       String
  projectId   String
  description String           @db.Text
  ownerId     String?
  deadline    DateTime?
  status      ActionItemStatus @default(OPEN)
  carriedOver Boolean          @default(false)
  meetingId   String?
  completedAt DateTime?

  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User?          @relation("ActionItemOwner", fields: [ownerId], references: [id])
  meeting MeetingRecord? @relation(fields: [meetingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([ownerId, status])
  @@index([projectId, status])
}

model NotificationRule {
  id             String         @id @default(cuid())
  orgId          String
  name           String
  triggerType    TriggerType
  channel        Channel
  recipients     RecipientGroup
  enabled        Boolean        @default(true)
  thresholdHours Int?

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model Notification {
  id     String           @id @default(cuid())
  orgId  String
  userId String
  type   NotificationType
  title  String
  body   String           @db.Text
  link   String?
  read   Boolean          @default(false)

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([userId, read])
}

model Settings {
  // R35.1: was a hardcoded `id = "singleton"`; now one row per org (1:1 with
  // Organization). The legacy default org keeps its existing "singleton" id value.
  id                      String  @id @default(cuid())
  orgId                   String  @unique
  weeksBehindMilestone    Int     @default(1)
  missedGoalsInARow       Int     @default(2)
  requireBoth             Boolean @default(false)
  submissionDeadlineHours Int     @default(24)
  statusSubmitWindowDays  Int     @default(3)
  statusLateWindowDays    Int     @default(3)

  // Org identity (R23.1) — defaults keep a stock deployment rendering as SEED.
  orgName        String @default("Turgor")
  orgFullName    String @default("Turgor")
  orgInstitution String @default("")
  orgLogoUrl     String @default("/turgor-logo.svg")
  // What a project cycle is called (R24.2) — display labels only; Project.semester stays generic.
  periodLabel    String @default("Semester")
  // Color family (R24.3, R32.4) — one of the 6 curated family ids in
  // src/lib/themes.ts. Legacy "custom" (R29.2, removed R32.4) is normalized to
  // "forest" on read. Per-user light/dark mode is a cookie, not a column.
  themePreset    String @default("forest")
  // Whole-app-name override (R29.3) — null derives via the R32.2 chain.
  appName        String?

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

enum CalendarEventType {
  PROJECT_MEETING
  NON_PROJECT_EVENT
  LEAD_MEETING
  EBOARD_MEETING
}

model CalendarEvent {
  id          String            @id @default(cuid())
  orgId       String
  title       String
  semester    String
  // Lead/eboard meetings can be pinned to multiple semesters (they govern Project
  // Standing submissions for every project in any of these). For other event types
  // this is just [semester]. Always includes `semester`.
  semesters   String[]          @default([])
  type        CalendarEventType @default(PROJECT_MEETING)
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean           @default(false)
  location    String?
  description String?           @db.Text
  projectId   String?
  org         Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  statusUpdates StatusUpdate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([semester, startsAt])
}
