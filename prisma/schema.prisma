generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Permission {
  VIEW_ALL_PROJECTS
  VIEW_ASSIGNED_PROJECTS
  SUBMIT_STATUS_UPDATES
  EDIT_OWN_PROJECT
  POST_MEETING_TRACKING
  MANAGE_PROJECTS
  MANAGE_MILESTONES
  ASSIGN_ACTION_ITEMS
  CLOSE_ACTION_ITEMS
  VIEW_MONTHLY_REVIEW
  CONFIGURE_NOTIFICATIONS
  MANAGE_USERS
  MANAGE_ROLES
  MANAGE_CALENDAR
  VIEW_LEAD_MEETINGS
  MANAGE_STATUS_UPDATES
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ProjectStatus {
  ON_TRACK
  AT_RISK
  BEHIND
}

// Shared status enum for Deliverable and Subtask
enum TimelineStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectMemberRole {
  LEAD
  SUBLEAD
  MEMBER
}

enum ActionItemStatus {
  OPEN
  DONE
}

enum TriggerType {
  MISSING_SUBMISSION
  PROJECT_BEHIND
  ACTION_ITEM_DUE
  GOAL_MISSED
}

enum Channel {
  EMAIL
  IN_APP
  BOTH
}

enum RecipientGroup {
  PM
  PROJECT_LEADS
  ACTION_OWNER
  ALL_ACTIVE
}

enum NotificationType {
  REMINDER
  PROJECT_BEHIND
  ACTION_ITEM
  GOAL_MISSED
  USER_APPROVAL
  GENERAL
  USER_SIGNUP
}

// ─── Auth adapter models (required by Auth.js Prisma adapter) ───────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ──────────────────────────────────────────────────────────

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  isBuiltIn   Boolean      @default(false)
  permissions Permission[]

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  firstName     String?
  lastName      String?
  nickname      String?
  mcpToken      String?    @unique
  status        UserStatus @default(PENDING)
  roleId        String?

  role               Role?               @relation(fields: [roleId], references: [id])
  accounts           Account[]
  sessions           Session[]
  projectAssignments ProjectAssignment[]
  statusUpdates      StatusUpdate[]
  meetingRecords     MeetingRecord[]
  assignedSubtasks   Subtask[]           @relation("SubtaskAssignee")
  actionItems        ActionItem[]        @relation("ActionItemOwner")
  notifications      Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                   String        @id @default(cuid())
  name                 String
  description          String?
  semester             String
  status               ProjectStatus @default(ON_TRACK)
  statusOverride       Boolean       @default(false)
  correctiveActionPlan String?       @db.Text
  startDate            DateTime?
  endDate              DateTime?

  assignments     ProjectAssignment[]
  deliverables    Deliverable[]
  statusUpdates   StatusUpdate[]
  meetingRecords  MeetingRecord[]
  actionItems     ActionItem[]
  calendarEvents  CalendarEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectAssignment {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Deliverable {
  id            String         @id @default(cuid())
  projectId     String
  title         String
  description   String?        @db.Text
  status        TimelineStatus @default(NOT_STARTED)
  startDate     DateTime?
  targetDate    DateTime
  completed     Boolean        @default(false)
  completedDate DateTime?
  orderIndex    Int            @default(0)
  group         String?
  priority      Priority       @default(MEDIUM)

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subtasks Subtask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subtask {
  id            String         @id @default(cuid())
  deliverableId String
  title         String
  description   String?        @db.Text
  status        TimelineStatus @default(NOT_STARTED)
  startDate     DateTime?
  dueDate       DateTime?
  orderIndex    Int            @default(0)
  assigneeId    String?
  completedAt   DateTime?

  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  assignee    User?       @relation("SubtaskAssignee", fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StatusUpdate {
  id             String   @id @default(cuid())
  projectId      String
  submittedById  String
  meetingDate    DateTime
  plannedWork    String   @db.Text
  actualProgress String   @db.Text
  blockers       String   @db.Text
  nextWeekGoals  String   @db.Text
  needsHelp      Boolean  @default(false)
  helpNeeded     String?  @db.Text
  submittedAt    DateTime @default(now())
  isLate         Boolean  @default(false)
  calendarEventId String?

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedBy   User           @relation(fields: [submittedById], references: [id])
  calendarEvent CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
}

model MeetingRecord {
  id           String        @id @default(cuid())
  projectId    String
  meetingDate  DateTime
  status       ProjectStatus
  goalMet      Boolean?
  keyBlockers  String?       @db.Text
  notes        String?       @db.Text
  recordedById String

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordedBy  User         @relation(fields: [recordedById], references: [id])
  actionItems ActionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActionItem {
  id          String           @id @default(cuid())
  projectId   String
  description String           @db.Text
  ownerId     String?
  deadline    DateTime?
  status      ActionItemStatus @default(OPEN)
  carriedOver Boolean          @default(false)
  meetingId   String?
  completedAt DateTime?

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User?          @relation("ActionItemOwner", fields: [ownerId], references: [id])
  meeting MeetingRecord? @relation(fields: [meetingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationRule {
  id             String         @id @default(cuid())
  name           String
  triggerType    TriggerType
  channel        Channel
  recipients     RecipientGroup
  enabled        Boolean        @default(true)
  thresholdHours Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  title  String
  body   String           @db.Text
  link   String?
  read   Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Settings {
  id                      String  @id @default("singleton")
  weeksBehindMilestone    Int     @default(1)
  missedGoalsInARow       Int     @default(2)
  requireBoth             Boolean @default(false)
  submissionDeadlineHours Int     @default(24)
  statusSubmitWindowDays  Int     @default(3)
  statusLateWindowDays    Int     @default(3)

  updatedAt DateTime @updatedAt
}

enum CalendarEventType {
  PROJECT_MEETING
  NON_PROJECT_EVENT
  LEAD_MEETING
  EBOARD_MEETING
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  semester    String
  // Lead/eboard meetings can be pinned to multiple semesters (they govern Project
  // Standing submissions for every project in any of these). For other event types
  // this is just [semester]. Always includes `semester`.
  semesters   String[]          @default([])
  type        CalendarEventType @default(PROJECT_MEETING)
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean           @default(false)
  location    String?
  description String?           @db.Text
  projectId   String?
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  statusUpdates StatusUpdate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([semester, startsAt])
}
